---
const { data } = (Astro.locals as any).starlightRoute.entry;
const { title = data.title, tagline, actions = [] } = data.hero || {};
---

<div class="jiang-hero">
  <div class="sl-flex jiang-hero-copy">
    <div class="sl-flex jiang-hero-text">
      <h1 id="_top" data-page-title set:html={title} />
      {tagline && <div class="tagline" set:html={tagline} />}
    </div>
    {
      actions.length > 0 && (
        <div class="sl-flex actions">
          {actions.map(({ attrs = {}, link: href, text, variant }: any) => {
            const { class: className, ...linkAttrs } = attrs;
            const external = href.startsWith('http');
            return (
              <a
                href={href}
                class:list={['jiang-link-button', variant === 'minimal' && 'minimal', className]}
                {...linkAttrs}
              >
                {text}
                {external ? <span aria-hidden="true">↗</span> : <span aria-hidden="true">→</span>}
              </a>
            );
          })}
        </div>
      )
    }
  </div>
  <div class="jiang-hero-logo-wrap" aria-hidden="true">
    <img class="jiang-hero-logo jiang-logo-light" src="/logo.svg" alt="" />
    <img class="jiang-hero-logo jiang-logo-dark" src="/logo-white.svg" alt="" />
  </div>
</div>

<style>
  .jiang-hero {
    display: grid;
    grid-template-columns: 1fr;
    align-items: center;
    gap: clamp(2rem, 7vw, 8rem);
    min-height: 30rem;
    padding-block: clamp(4rem, 10vw, 7rem);
  }

  .jiang-hero-copy,
  .jiang-hero-text {
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .jiang-hero-copy {
    gap: clamp(1.5rem, calc(1.5rem + 1vw), 2rem);
  }

  .jiang-hero-text {
    gap: 1rem;
  }

  .jiang-hero-text > * {
    max-width: 50ch;
  }

  h1 {
    margin-top: 0;
    font-size: clamp(var(--sl-text-3xl), calc(0.25rem + 5vw), var(--sl-text-6xl));
    line-height: var(--sl-line-height-headings);
    font-weight: 600;
    color: var(--sl-color-white);
  }

  .tagline {
    font-size: clamp(var(--sl-text-base), calc(0.0625rem + 2vw), var(--sl-text-xl));
    color: var(--sl-color-gray-2);
  }

  .actions {
    gap: 1rem 2rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .jiang-link-button {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    border-radius: 999rem;
    padding: 0.75rem 1.35rem;
    background: var(--sl-color-accent);
    color: var(--sl-color-text-invert);
    font-weight: 600;
    line-height: 1;
    text-decoration: none;
    box-shadow: var(--sl-shadow-sm);
  }

  .jiang-link-button:hover {
    color: var(--sl-color-text-invert);
    background: var(--sl-color-accent-high);
  }

  .jiang-hero-logo-wrap {
    order: -1;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .jiang-hero-logo {
    display: block;
    width: min(62vw, 11rem);
    height: auto;
  }

  .jiang-logo-dark {
    display: none;
  }

  :root[data-theme='dark'] .jiang-logo-light {
    display: none;
  }

  :root[data-theme='dark'] .jiang-logo-dark {
    display: block;
  }

  @media (min-width: 50rem) {
    .jiang-hero {
      grid-template-columns: minmax(0, 1.05fr) minmax(18rem, 0.95fr);
    }

    .jiang-hero-logo-wrap {
      order: 2;
    }

    .jiang-hero-logo {
      width: min(100%, 24rem);
    }

    .jiang-hero-copy,
    .jiang-hero-text {
      align-items: flex-start;
      text-align: left;
    }

    .actions {
      justify-content: flex-start;
    }
  }
</style>
